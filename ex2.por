programa {
  funcao inicio() {
    cadeia comida[3]
    escreva ("digite sua comida favorita: \n")
    leia (comida[0])
    escreva (comida[0],"\n")
    escreva ("digite sua segunda comida favorita \n")
    leia (comida[1])
    escreva (comida [1],"\n")
    escreva ("digite sua terceira comida favorita\n")
    leia (comida[2])
    escreva (comida [2],"\n")


  }
}
