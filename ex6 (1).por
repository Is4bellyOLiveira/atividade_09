programa {
  funcao inicio() {
    inteiro vetor[4]
    escreva ("Escreva o valor 1: ")
    leia (vetor[0])
    escreva ("\nEscreva o valor 2: ")
    leia (vetor[1])
    escreva ("\nEscreva o valor 3: ")
    leia (vetor[2])
    escreva ("\nEscreva o valor 4: ")
    leia(vetor[3])

    se (vetor[0] == vetor[3])
    escreva ("posição 1 é igual a posição 4")
    senao
    escreva("posição 1 é diferente da posição 4")





  }
}
